# Push Notification Service (Web Push via VAPID)
# Generate keys with: npx web-push generate-vapid-keys

# VAPID Keys (required)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_EMAIL=admin@yourdomain.com

# Scheduled Reminders
REMINDER_HOUR=20

# PocketBase Integration (for scheduled job)
POCKETBASE_TOKEN=
